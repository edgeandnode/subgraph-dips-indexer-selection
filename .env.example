# Google Cloud Platform
IISA_GCP_PROJECT=your-gcp-project-id
IISA_GCP_LOCATION=US

# IPinfo.io API for GeoIP resolution
IISA_IPINFO_API_KEY=your-ipinfo-api-key

# Service configuration
IISA_HOST=0.0.0.0
IISA_PORT=8080
IISA_LOG_LEVEL=INFO

# Data configuration
IISA_NUM_DAYS_LOOKBACK=28

# GCP credentials path (mount this file in Docker)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json
