# Service configuration
IISA_HOST=0.0.0.0
IISA_PORT=8080
IISA_LOG_LEVEL=INFO
SCORES_FILE_PATH=/app/scores/indexer_scores.json

# -------------------------------------------------------------------
# Kubernetes secrets (create via kubectl, not committed to git)
# -------------------------------------------------------------------
#
# Redpanda credentials (secret: iisa-redpanda-credentials)
#   kubectl create secret generic iisa-redpanda-credentials \
#     --namespace=subgraph-dips-indexer-selection-iisa-daily-cronjob-samuel \
#     --from-literal=sasl_username=<username> \
#     --from-literal=sasl_password=<password>
#
# Graph Network subgraph URL (secret: iisa-graph-network-credentials)
# URL contains an API key — get one at https://thegraph.com/studio/apikeys/
#   kubectl create secret generic iisa-graph-network-credentials \
#     --namespace=subgraph-dips-indexer-selection-iisa-daily-cronjob-samuel \
#     --from-literal=subgraph_url=https://gateway.thegraph.com/api/<API_KEY>/subgraphs/id/DZz4kDTdmzWLWsV373w2bSmoar3umKKH9y82SUKr5qmp
